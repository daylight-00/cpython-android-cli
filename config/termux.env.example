# Copy to .local/env on Termux and edit paths or remote aliases as needed.

PROJECT_ROLE=termux

CPYTHON_RUNTIME_ARCHIVE="$HOME/uv-base/cpython-3.14-aarch64-linux-android-for-uv.tar.gz"

# Optional artifact pull settings for topologies where Termux can initiate
# outbound SSH to the build workstation but cannot accept inbound SSH.
ARTIFACT_SOURCE_REMOTE=victor
ARTIFACT_SOURCE_PROJECT_ROOT="/home/hwjang/tmp/cpython-android-cli"
