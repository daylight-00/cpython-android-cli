# Copy to .local/env on Termux and edit paths or remote aliases as needed.

PROJECT_ROLE=termux

# The default runtime archive is the synchronized promoted product under:
#   out/$TARGET_ID/$BUILD_PROFILE/cpython/
# Do not set CPYTHON_RUNTIME_ARCHIVE for the canonical workflow.
# Use an explicit override only for isolated historical comparison.

# Required artifact pull settings for topologies where Termux can initiate
# outbound SSH to the build workstation but cannot accept inbound SSH.
ARTIFACT_SOURCE_REMOTE=victor
ARTIFACT_SOURCE_PROJECT_ROOT="/home/hwjang/tmp/cpython-android-cli"
