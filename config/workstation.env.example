# Copy to .local/env on the Linux workstation and edit paths.

PROJECT_ROLE=workstation

# Cross compiler executable.
ANDROID_CC="$HOME/tmp/tools/Android/ndk/27.3.13750724/toolchains/llvm/prebuilt/linux-x86_64/bin/aarch64-linux-android24-clang"

# Development prefix containing Python.h, pyconfig.h, and libpython3.14.so.
CPYTHON_DEV_PREFIX="$HOME/tmp/260703/android-python-work/prefix"

# Optional rsync deployment settings.
SYNC_REMOTE=termux
SYNC_REMOTE_PROJECT_ROOT="/data/data/com.termux/files/home/src/cpython-android-cli"
