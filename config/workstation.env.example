# Copy to .local/env on the Linux workstation and edit only settings that
# differ from the repo-local defaults.
#
# project-env.sh defines PROJECT_ROOT before sourcing .local/env, so paths
# below remain valid if the whole repository is moved.

PROJECT_ROLE=workstation

# Cross compiler executable from the repo-local Android NDK tree.
ANDROID_CC="$PROJECT_ROOT/tools/Android/ndk/27.3.13750724/toolchains/llvm/prebuilt/linux-x86_64/bin/aarch64-linux-android24-clang"

# Android CPython development prefix used to build the launcher.
# This prefix must contain:
#   include/python3.14/Python.h
#   include/python3.14/pyconfig.h
#   lib/libpython3.14.so
CPYTHON_DEV_PREFIX="$PROJECT_ROOT/experiments/bootstrap-android-build/android-python-work/prefix"

# Optional rsync deployment settings.
SYNC_REMOTE=termux
SYNC_REMOTE_PROJECT_ROOT="/data/data/com.termux/files/home/src/cpython-android-cli"
