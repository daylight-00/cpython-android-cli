# cpython-android-cli
#
# Track source, experiment code, selected evidence, documentation,
# and reproducibility metadata.
# Keep generated runtimes, toolchains, extracted prefixes, caches,
# and bulk results repo-local but untracked.

# Machine-local configuration
/.local/
/.config/local.env
.env
.env.*
!.env.example

# External SDKs, toolchains, and upstream working trees
/tools/

# Canonical generated trees
/out/
/work/
/results/
/dist/
/cache/

# Generated experiment trees
**/out/
**/dist/
**/results/
**/*-results/
**/*-results-v*/
**/pristine/
**/pristine-v*/
**/pristine-test/
**/stage2b-relocation/

# Extracted/installed runtime prefixes
**/prefix/

# Generated bootstrap workspace
experiments/bootstrap-android-build/android-python-work/testbed/

# Archives and packages
*.tar
*.tar.gz
*.tgz
*.zip

# Historical direct binary copies
/experiments/stage1b-pyconfig/python-pyconfig-auto
/experiments/stage1b-pyconfig/python-pyconfig-home
/experiments/stage2a-bootstrap-strategies/python-pyconfig-auto
/experiments/stage2a-bootstrap-strategies/python-s2-linker-update
/experiments/stage2a-bootstrap-strategies/python-s2-reexec
/experiments/stage2a-bootstrap-strategies/python-s2-setenv
/experiments/stage2b-conditional-reexec/python-s2-r2

# Python generated files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Native compiler leftovers
*.o
*.obj
*.a
*.lo
*.la

# Do not globally ignore *.so:
# selected ELF fixtures/evidence may be tracked deliberately.
# Generated shared libraries are already excluded via prefix/out/work.

# Editors and OS noise
*.swp
*.swo
*~
.DS_Store
.idea/
.vscode/
