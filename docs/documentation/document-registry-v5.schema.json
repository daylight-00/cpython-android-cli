    },
    "documents": {
      "items": {
        "required": [
          "path",
          "format",
          "lifecycle_class",
          "authority_domain",
          "owner",
          "mutability",
          "update_trigger",
          "supersession_rule",
          "onboarding_visibility",
          "machine_binding_policy",
          "migration_action"
