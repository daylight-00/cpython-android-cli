#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[3]
LIB = ROOT / "components/upstream-thin/lib"


def main() -> int:
    commands = {"assemble-full", "verify-full", "qualify-full", "assemble-install-only", "verify-install-only", "qualify-install-only", "assemble-stripped", "verify-stripped", "qualify-stripped", "assemble-family", "verify-family", "census-licenses", "resolve-license-provenance", "acquire-license-evidence", "integrate-legal-family", "verify-legal-family", "observe-astral", "assemble-data", "verify-data", "install-data", "activate-data", "qualify-data", "test"}
    if len(sys.argv) < 2 or sys.argv[1] not in commands:
        print("usage: cpython-android-upstream-thin {assemble-full|verify-full|qualify-full|assemble-install-only|verify-install-only|qualify-install-only|assemble-stripped|verify-stripped|qualify-stripped|assemble-family|verify-family|census-licenses|resolve-license-provenance|acquire-license-evidence|integrate-legal-family|verify-legal-family|observe-astral|assemble-data|verify-data|install-data|activate-data|qualify-data|test} ...", file=sys.stderr)
        return 2
    command = sys.argv[1]
    if command == "test":
        return subprocess.call([sys.executable, "-m", "unittest", "discover", "-s", str(ROOT / "components/upstream-thin/tests"), "-v"], cwd=ROOT)
    implementations = {
        "assemble-full": "assemble_full.py",
        "verify-full": "verify_full.py",
        "qualify-full": "qualify_full.py",
        "assemble-install-only": "assemble_install_only.py",
        "verify-install-only": "verify_install_only.py",
        "qualify-install-only": "qualify_install_only.py",
        "assemble-stripped": "assemble_stripped.py",
        "verify-stripped": "verify_stripped.py",
        "qualify-stripped": "qualify_stripped.py",
        "assemble-family": "release_family.py",
        "verify-family": "release_family.py",
        "census-licenses": "license_census.py",
        "resolve-license-provenance": "license_provenance.py",
        "acquire-license-evidence": "license_payloads.py",
        "integrate-legal-family": "legal_integration.py",
        "verify-legal-family": "legal_integration.py",
        "observe-astral": "observe_astral.py",
        "assemble-data": "data_products.py",
        "verify-data": "data_products.py",
        "install-data": "data_products.py",
        "activate-data": "data_products.py",
        "qualify-data": "data_products.py",
    }
    implementation = LIB / implementations[command]
    env = os.environ.copy()
    env["PYTHONPATH"] = str(LIB) + (os.pathsep + env["PYTHONPATH"] if env.get("PYTHONPATH") else "")
    data_actions = {"assemble-data": "assemble", "verify-data": "verify", "install-data": "install", "activate-data": "activate", "qualify-data": "qualify"}
    extra = ["assemble"] if command in {"assemble-family", "integrate-legal-family"} else ["verify"] if command in {"verify-family", "verify-legal-family"} else [data_actions[command]] if command in data_actions else []
    return subprocess.call([sys.executable, str(implementation), *extra, *sys.argv[2:]], cwd=ROOT, env=env)


if __name__ == "__main__":
    raise SystemExit(main())
